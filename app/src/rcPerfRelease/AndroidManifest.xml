<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- App-defined signature permissions reject adb shell senders; DUMP keeps shell collection. -->
        <service
            android:name=".rcperf.RcPerfHarnessService"
            android:exported="true"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="com.bytedance.zgx.solin.rcperf.RUN" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="rc_perf_collection" />
        </service>
    </application>
</manifest>
